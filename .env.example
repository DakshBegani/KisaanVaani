# ── OpenWeatherMap ────────────────────────────────────────────────────────────
# Free tier at https://openweathermap.org/api
OPEN_WEATHER_API_KEY=your_openweather_api_key_here

# ── AWS ────────────────────────────────────────────────────────────────────────
# AWS credentials for Bedrock (LLM), Transcribe (STT), Polly (TTS), and S3.
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Option 1 – Long-term credentials (IAM user access key):
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=ap-south-1
#
# Option 2 – If you use AWS SSO / assumed role, run:
#   aws sso login --profile <your-profile>
# and set AWS_PROFILE=<your-profile> here (leave the key vars blank):
# AWS_PROFILE=your_sso_profile_name

